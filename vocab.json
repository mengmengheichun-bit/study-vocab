          "id": 1779027203192,
          "name": "task 1",
          "items": [
            {
              "id": 1779027238622,
              "word": "decreased substantially",
              "pos": "verb + adverb",
              "pron": "",
              "mean": "giảm đáng kể / giảm mạnh",
              "example": "Overall, air pollution decreased substantially over the period."
            },
            {
              "id": 1779027233201,
              "word": "mainly due to a major fall in industrial emissions",
              "pos": "cause phrase",
              "pron": "",
              "mean": "chủ yếu do sự sụt giảm lớn trong khí thải công nghiệp",
              "example": "The overall decline was mainly due to a major fall in industrial emissions."
            },
            {
              "id": 1779027234861,
              "word": "a major fall in industrial emissions",
              "pos": "noun phrase",
              "pron": "",
              "mean": "một sự sụt giảm lớn trong khí thải công nghiệp",
              "example": "There was a major fall in industrial emissions between 1990 and 2005."
            },
            {
              "id": 1779027232848,
              "word": "the largest individual source",
              "pos": "noun phrase",
              "pron": "",
              "mean": "nguồn riêng lẻ lớn nhất",
              "example": "Industry was the largest individual source of air pollutants throughout the period."
            },
            {
              "id": 1779027232767,
              "word": "remained comparatively low and stable",
              "pos": "verb phrase",
              "pron": "",
              "mean": "duy trì tương đối thấp và ổn định",
              "example": "Transport remained comparatively low and stable throughout the period."
            },
            {
              "id": 1779027239249,
              "word": "declined steadily",
              "pos": "verb + adverb",
              "pron": "",
              "mean": "giảm đều đặn",
              "example": "Household pollution declined steadily after 1990."
            },
            {
              "id": 1779027237110,
              "word": "became almost negligible",
              "pos": "verb phrase",
              "pron": "",
              "mean": "trở nên gần như không đáng kể",
              "example": "Household emissions became almost negligible by 2005."
            },
            {
              "id": 1779027234061,
              "word": "falling steadily",
              "pos": "verb-ing phrase",
              "pron": "",
              "mean": "giảm đều đặn",
              "example": "Total air pollution fell from 7 million tonnes to 5 million tonnes, falling steadily in the early years."
            },
            {
              "id": 1779027234702,
              "word": "levelled off slightly",
              "pos": "verb + adverb",
              "pron": "",
              "mean": "chững lại nhẹ / đi ngang nhẹ",
              "example": "The figure then levelled off slightly at just 4 million tonnes."
            },
            {
              "id": 1779027239113,
              "word": "followed a similar but even sharper downward pattern",
              "pos": "verb phrase",
              "pron": "",
              "mean": "theo một xu hướng giảm tương tự nhưng còn rõ/mạnh hơn",
              "example": "Industry followed a similar but even sharper downward pattern."
            },
            {
              "id": 1779027238345,
              "word": "dropped markedly",
              "pos": "verb + adverb",
              "pron": "",
              "mean": "giảm rõ rệt / giảm mạnh",
              "example": "Industrial emissions dropped markedly to around 3 million tonnes in 1996."
            },
            {
              "id": 1779027236357,
              "word": "had fallen further to about",
              "pos": "past perfect phrase",
              "pron": "",
              "mean": "đã giảm thêm xuống khoảng",
              "example": "By the end of the period, industrial emissions had fallen further to about 2 million tonnes."
            },
            {
              "id": 1779027233524,
              "word": "much smaller throughout",
              "pos": "adjective phrase",
              "pron": "",
              "mean": "nhỏ hơn nhiều trong suốt giai đoạn",
              "example": "The other two sources were much smaller throughout."
            },
            {
              "id": 1779027238800,
              "word": "remained close to this level for the whole period",
              "pos": "verb phrase",
              "pron": "",
              "mean": "duy trì gần mức này trong suốt giai đoạn",
              "example": "Transport remained close to this level for the whole period."
            },
            {
              "id": 1779027235591,
              "word": "reached almost zero",
              "pos": "verb phrase",
              "pron": "",
              "mean": "chạm mức gần như bằng 0",
              "example": "Household emissions reached almost zero by 2005."
            }
          ]
